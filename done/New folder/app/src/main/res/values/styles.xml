<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AdminCardStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">150dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">10dp</item>
        <item name="cardCornerRadius">15dp</item>
        <item name="cardElevation">6dp</item>
    </style>

    <style name="AdminCardContent">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">16dp</item>
    </style>

    <style name="AdminIconStyle">
        <item name="android:layout_width">50dp</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:layout_marginBottom">10dp</item>
        <item name="android:tint">#475569</item>
    </style>

    <style name="AdminTextStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#1E293B</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>