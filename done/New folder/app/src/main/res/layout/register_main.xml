<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="40dp">

        <View
            android:id="@+id/topView"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="#475569"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/txtRegTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ĐĂNG KÝ THÀNH VIÊN"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="40dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="25dp"
            app:cardElevation="12dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/txtRegTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_percent="0.92">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="25dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ẢNH ĐẠI DIỆN"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_gravity="center" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAvatar"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="40dp"
                    app:cardBackgroundColor="#F1F5F9">
                    <ImageView
                        android:id="@+id/imgProfile"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerInside"
                        android:src="@android:drawable/ic_menu_camera"
                        android:padding="20dp"
                        android:tint="#94A3B8" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HỌ VÀ TÊN (*)"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold" />
                <EditText
                    android:id="@+id/edtRegFullName"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Nhập họ và tên"
                    android:textColorHint="#CBD5E1"
                    android:background="@android:drawable/edit_text"
                    android:backgroundTint="#F8FAFC"
                    android:paddingStart="15dp"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GIỚI TÍNH"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold" />
                <RadioGroup
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <RadioButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nam"
                        android:checked="true"
                        android:textSize="14sp" />
                    <RadioButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nữ"
                        android:layout_marginStart="20dp"
                        android:textSize="14sp" />
                </RadioGroup>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EMAIL (*)"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold" />
                <EditText
                    android:id="@+id/edtRegEmail"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="vidu@gmail.com"
                    android:inputType="textEmailAddress"
                    android:textColorHint="#CBD5E1"
                    android:background="@android:drawable/edit_text"
                    android:backgroundTint="#F8FAFC"
                    android:paddingStart="15dp"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SỐ ĐIỆN THOẠI (*)"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold" />
                <EditText
                    android:id="@+id/edtRegPhone"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Nhập số điện thoại"
                    android:inputType="phone"
                    android:textColorHint="#CBD5E1"
                    android:background="@android:drawable/edit_text"
                    android:backgroundTint="#F8FAFC"
                    android:paddingStart="15dp"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ĐỊA CHỈ"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold" />
                <EditText
                    android:id="@+id/edtRegAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:hint="Số nhà, tên đường, phường/xã..."
                    android:textColorHint="#CBD5E1"
                    android:background="@android:drawable/edit_text"
                    android:backgroundTint="#F8FAFC"
                    android:paddingStart="15dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MẬT KHẨU (*)"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold" />
                <EditText
                    android:id="@+id/edtRegPass"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Nhập mật khẩu ít nhất 6 ký tự"
                    android:inputType="textPassword"
                    android:textColorHint="#CBD5E1"
                    android:background="@android:drawable/edit_text"
                    android:backgroundTint="#F8FAFC"
                    android:paddingStart="15dp"
                    android:layout_marginBottom="20dp" />

                <CheckBox
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tôi đồng ý với các điều khoản của shop"
                    android:textSize="13sp"
                    android:textColor="#94A3B8"
                    android:layout_marginBottom="20dp" />

                <Button
                    android:id="@+id/btnRegister"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:backgroundTint="#475569"
                    android:text="HOÀN TẤT ĐĂNG KÝ"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    app:cornerRadius="12dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>