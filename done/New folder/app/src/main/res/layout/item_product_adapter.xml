<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="5dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vimen Store"
                android:textStyle="bold"
                android:textColor="@color/text_black"
                android:drawableStart="@android:drawable/ic_menu_myplaces"
                android:drawablePadding="5dp"/>
            <TextView
                android:id="@+id/tvStatusAdapter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="Hoàn thành"
                android:textColor="@color/vimen_accent"/> </RelativeLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F1F1" android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <ImageView
                android:id="@+id/imgProductAdapter"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_launcher_background" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/txtNameProductAdapter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tên sản phẩm siêu cấp Vimen"
                    android:textColor="@color/text_black"
                    android:maxLines="2"
                    android:ellipsize="end"/>
                <TextView
                    android:id="@+id/tvSizeAdapter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kích thước: L"
                    android:textColor="@color/text_grey_light"
                    android:textSize="12sp"
                    android:layout_marginTop="3dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">
                <TextView
                    android:id="@+id/tvPriceAdapter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="350.000 VNĐ"
                    android:textColor="@color/text_black"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvQuantityAdapter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="x1"
                    android:textColor="@color/text_grey_light"
                    android:textSize="12sp"
                    android:layout_marginTop="3dp"/>
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F1F1" android:layout_marginVertical="12dp"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 sản phẩm"
                android:textColor="@color/text_grey_light"
                android:textSize="12sp"/>
            <TextView
                android:id="@+id/tvTotalPriceAdapter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="Tổng số tiền: 350.000 VNĐ"
                android:textColor="@color/vimen_primary"
                android:textStyle="bold"/>
        </RelativeLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F1F1" android:layout_marginVertical="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <Button
                android:id="@+id/btnCancelOrderAdapter"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:backgroundTint="#F0F0F0"
                android:text="Hủy đơn"
                android:textAllCaps="false"
                android:textColor="@color/text_grey_dark"
                android:textSize="13sp"
                android:layout_marginEnd="10dp"
                android:visibility="gone"/> <Button
            android:id="@+id/btnBuyAgainAdapter"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:backgroundTint="@color/vimen_primary"
            android:text="Mua lại"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="13sp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>