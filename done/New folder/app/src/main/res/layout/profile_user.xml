<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/vimen_primary"
            android:padding="10dp">
            <ImageView
                android:id="@+id/btnBackProfile"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="#FFFFFF" />
            <ImageView
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="40dp"
                android:src="@android:drawable/ic_menu_manage"
                app:tint="#FFFFFF" />
            <ImageView
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:layout_alignParentEnd="true"
                android:src="@android:drawable/stat_notify_chat"
                app:tint="#FFFFFF" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/vimen_primary"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="20dp">
            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:src="@drawable/logo"
                app:shapeAppearanceOverlay="@style/CircleImage"
                app:strokeColor="#FFFFFF"
                app:strokeWidth="2dp" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvProfileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trần Châu Tuấn"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvProfileEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="tuantc@vimenstore.com"
                    android:textColor="#F1F1F1"
                    android:textSize="13sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:background="@android:color/white"
                    android:paddingHorizontal="8dp"
                    android:text="Thành viên Bạc"
                    android:textColor="@color/vimen_primary"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/btnGoToOrders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đơn mua"
                        android:textStyle="bold"
                        android:textColor="#333333"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="Xem lịch sử mua hàng >"
                        android:textColor="#888888"
                        android:textSize="12sp"/>
                </RelativeLayout>
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#EEEEEE" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="15dp">
                    <LinearLayout android:id="@+id/btnWaitingConfirm" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@android:drawable/ic_menu_edit" app:tint="#555555" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="Chờ xác nhận" android:textSize="11sp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@android:drawable/ic_menu_send" app:tint="#555555" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="Chờ lấy hàng" android:textSize="11sp" />
                    </LinearLayout>
                    <LinearLayout android:id="@+id/btnShipping" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@android:drawable/ic_dialog_map" app:tint="#555555" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="Đang giao" android:textSize="11sp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@android:drawable/btn_star_big_off" app:tint="#555555" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="Đánh giá" android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="8dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tiện ích của tôi"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="15dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <ImageView android:layout_width="25dp" android:layout_height="25dp" android:src="@android:drawable/ic_menu_save" app:tint="#EE4D2D" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ví VimenPay" android:textSize="11sp" android:layout_marginTop="5dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0đ" android:textSize="10sp" android:textColor="#888888"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <ImageView android:layout_width="25dp" android:layout_height="25dp" android:src="@android:drawable/btn_star_big_on" app:tint="#FFC107" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Vimen Xu" android:textSize="11sp" android:layout_marginTop="5dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="100 Xu" android:textSize="10sp" android:textColor="#888888"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <ImageView android:layout_width="25dp" android:layout_height="25dp" android:src="@android:drawable/ic_menu_agenda" app:tint="#EE4D2D" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kho Voucher" android:textSize="11sp" android:layout_marginTop="5dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12 Voucher" android:textSize="10sp" android:textColor="#888888"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="8dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dịch vụ tài chính"
                        android:textStyle="bold"
                        android:textColor="#333333"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="Xem thêm >"
                        android:textColor="#888888"
                        android:textSize="12sp"/>
                </RelativeLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="15dp"
                    android:paddingHorizontal="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Vay Tiền Nhanh\nNhận đến 50tr" android:textSize="11sp" android:gravity="center" android:drawableTop="@android:drawable/ic_menu_recent_history"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Bảo hiểm của tôi\nMua ngay!" android:textSize="11sp" android:gravity="center" android:drawableTop="@android:drawable/ic_menu_view"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_margin="20dp"
            android:background="@drawable/bg_logout_button"
            android:text="Đăng xuất"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>