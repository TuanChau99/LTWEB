<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thông tin nhóm sản phẩm"
        android:textStyle="bold"
        android:textSize="18sp"
        android:layout_marginBottom="15dp"/>

    <EditText
        android:id="@+id/edtCatName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Tên nhóm (VD: Giày Thể Thao)"
        android:inputType="textCapWords" />

    <EditText
        android:id="@+id/edtCatImage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:hint="Tên file ảnh (VD: giay_nike)"
        android:inputType="text" />

    <Button
        android:id="@+id/btnSaveCat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="LƯU THÔNG TIN"
        android:backgroundTint="#1E293B"
        android:textColor="@android:color/white" />
</LinearLayout>