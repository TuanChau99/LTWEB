<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="260dp"
    android:layout_height="90dp"
    android:layout_marginEnd="16dp"
    android:background="@drawable/bg_voucher_item"> <View
    android:id="@+id/viewAccent"
    android:layout_width="8dp"
    android:layout_height="match_parent"
    android:background="#10B981"
    app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvVoucherCode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:text="VIMEN50K"
        android:textColor="#111827"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/viewAccent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvVoucherDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="12dp"
        android:text="Giảm 50k đơn từ 500k"
        android:textColor="#6B7280"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/tvVoucherCode"
        app:layout_constraintTop_toBottomOf="@id/tvVoucherCode" />

    <TextView
        android:id="@+id/tvVoucherExpiry"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="HSD: 30/12/2026"
        android:textColor="#9CA3AF"
        android:textSize="10sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/tvVoucherCode" />

</androidx.constraintlayout.widget.ConstraintLayout>