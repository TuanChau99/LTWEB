<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SỬA THÔNG TIN SẢN PHẨM"
        android:textColor="#00008B"
        android:textStyle="bold"
        android:gravity="center"
        android:textSize="18sp"
        android:layout_marginBottom="15dp"/>

    <EditText
        android:id="@+id/edtEditProductName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/edittext_border_yellow"
        android:padding="10dp"
        android:layout_marginBottom="10dp"
        android:hint="Tên sản phẩm"/>

    <EditText
        android:id="@+id/edtEditProductPrice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/edittext_border_yellow"
        android:padding="10dp"
        android:layout_marginBottom="10dp"
        android:hint="Giá sản phẩm"/>

    <EditText
        android:id="@+id/edtEditProductDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/edittext_border_yellow"
        android:padding="10dp"
        android:layout_marginBottom="10dp"
        android:hint="Mô tả"/>

    <EditText
        android:id="@+id/edtEditProductImages"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/edittext_border_yellow"
        android:padding="10dp"
        android:layout_marginBottom="10dp"
        android:hint="Tên ảnh (vd: giay_nike)"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/imgEditPreview"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@android:drawable/ic_menu_gallery"
            android:background="@drawable/edittext_border_yellow"
            android:padding="5dp"/>

        <Button
            android:id="@+id/btnSelectImage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="Chọn ảnh"
            android:backgroundTint="#F44336"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <Spinner
        android:id="@+id/spnEditCategory"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:layout_marginTop="10dp"/>

</LinearLayout>