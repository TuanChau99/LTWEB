<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/backgroud"
    tools:context=".MainActivity">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#40000000" />

    <androidx.cardview.widget.CardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="30dp"
        app:cardElevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.85">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="35dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="VIMEN STORE"
                android:textAlignment="center"
                android:textColor="#334155"
                android:textSize="26sp"
                android:letterSpacing="0.1"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Thời trang nam cao cấp"
                android:textAlignment="center"
                android:textColor="#94A3B8"
                android:textSize="13sp"
                android:layout_marginBottom="35dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TÀI KHOẢN"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp" />

            <EditText
                android:id="@+id/edtUsername"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Email hoặc số điện thoại"
                android:textColorHint="#CBD5E1"
                android:inputType="text"
                android:background="@android:drawable/edit_text"
                android:backgroundTint="#F1F5F9"
                android:paddingStart="16dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="18dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MẬT KHẨU"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp" />

            <EditText
                android:id="@+id/edtPassword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="••••••••"
                android:textColorHint="#CBD5E1"
                android:inputType="textPassword"
                android:background="@android:drawable/edit_text"
                android:backgroundTint="#F1F5F9"
                android:paddingStart="16dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="25dp" />

            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:backgroundTint="#475569"
                android:text="ĐĂNG NHẬP"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Quên mật khẩu?"
                android:textAlignment="center"
                android:textColor="#94A3B8"
                android:layout_marginTop="20dp"
                android:textSize="13sp"
                android:textStyle="italic" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="15dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chưa có tài khoản? "
                    android:textColor="#94A3B8"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/txtGoToRegister"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đăng ký ngay"
                    android:textColor="#475569"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>