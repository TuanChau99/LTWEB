<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
        <TextView android:id="@+id/tvUsername" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Username: admin" android:textColor="#1E293B"/>
        <TextView android:id="@+id/tvPassword" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Password: 123" android:textSize="12sp"/>
        <TextView android:id="@+id/tvRules" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rules: admin" android:textColor="#10B981" android:textStyle="bold"/>
    </LinearLayout>

    <ImageView android:id="@+id/btnEditUser" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_edit" android:layout_marginEnd="10dp"/>
    <ImageView android:id="@+id/btnDeleteUser" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_delete"/>
</LinearLayout>